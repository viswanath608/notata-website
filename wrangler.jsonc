{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "notata-website",
    "compatibility_date": "2026-07-08",
    "observability": {
        "enabled": true
    },
    "assets": {
        "directory": "./dist",
        "not_found_handling": "single-page-application"
    },
    "compatibility_flags": [
        "nodejs_compat"
    ]
}